{
  "name": "automation_marriott",
  "version": "1.0.0",
  "description": "Playwright automation suite for RedBus scenarios using Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:spec": "playwright test tests/spec.ts --project=chromium",
    "test:spec:all": "playwright test tests/spec.ts",
    "test:spec:visual": "playwright test tests/spec.ts --project=chromium --headed --workers=1 --reporter=line",
    "test:spec:debug": "playwright test tests/spec.ts --project=chromium --debug --workers=1",
    "test:spec:trace": "playwright test tests/spec.ts --project=chromium --headed --workers=1 --trace on",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "allure-commandline": "^2.38.1"
  },
  "dependencies": {
    "allure-playwright": "^3.7.1"
  }
}
